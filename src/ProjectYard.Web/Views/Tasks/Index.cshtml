@model List<ProjectYard.Data.Entities.Task>
@{
    ViewData["Title"] = "Tasks";
    var cols = new[] { ("todo", "Por fazer"), ("doing", "Em curso"), ("review", "Em revisão"), ("done", "Concluído") };
    string PrioCls(string p) => p == "Alta" ? "b-red" : p == "Média" ? "b-amber" : "b-gray";
}
<div class="content">
    <div class="page-head"><div><h1>Tasks</h1><p>Quadro Kanban — @Model.Count tarefas.</p></div></div>
    <div class="grid" style="grid-template-columns:repeat(4,1fr);align-items:start;">
        @foreach (var (key, label) in cols)
        {
            var items = Model.Where(t => t.State == key).ToList();
            <div>
                <div style="display:flex;align-items:center;gap:8px;padding:0 4px 12px;">
                    <span style="font-weight:700;font-size:14px;">@label</span>
                    <span class="badge b-gray">@items.Count</span>
                </div>
                <div style="display:flex;flex-direction:column;gap:10px;">
                    @foreach (var t in items)
                    {
                        <div class="card card-pad" style="padding:14px;">
                            <div style="font-weight:600;font-size:13.5px;line-height:1.35;margin-bottom:10px;">@t.Title</div>
                            <div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap;">
                                <span class="badge @PrioCls(t.Priority)">@t.Priority</span>
                                <span class="badge b-gray">@(t.Project?.Code ?? "")</span>
                                @if (t.Overdue) { <span class="badge b-red">Atrasada</span> }
                                <span class="muted-3" style="margin-left:auto;font-size:11.5px;font-weight:600;">@(t.Assignee?.Name ?? "—")</span>
                            </div>
                        </div>
                    }
                    @if (items.Count == 0) { <div class="muted" style="padding:10px 4px;font-size:13px;">Vazio</div> }
                </div>
            </div>
        }
    </div>
</div>
