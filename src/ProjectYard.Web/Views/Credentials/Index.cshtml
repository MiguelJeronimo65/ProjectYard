@model List<ProjectYard.Data.Entities.PortalCredential>
@{
    ViewData["Title"] = "Acessos a portais";
    string? q = ViewBag.Q;
    var projects = (List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)ViewBag.Projects;
    string sel() => "border:none;outline:none;background:transparent;flex:1;font-size:14px;font-weight:600;color:var(--text);";
}
<div class="content">
    <div class="page-head">
        <div><h1>Acessos a portais</h1><p>Logins de câmaras e entidades para licenciamento · passwords cifradas</p></div>
        <div class="page-head__actions">
            <button class="btn btn-primary" type="button" onclick="pcOpen()">@Icons.Render("plus", 16) Novo acesso</button>
        </div>
    </div>

    <form method="get" style="margin-bottom:16px;max-width:420px;">
        <div class="search" style="width:100%;">@Icons.Render("search", 17)<input name="q" value="@q" placeholder="Procurar por nome, portal, utilizador…" /></div>
    </form>

    <div style="display:flex;align-items:center;gap:11px;padding:12px 16px;background:var(--accent-soft);border-radius:var(--r-sm);font-size:13px;font-weight:600;color:var(--accent-700);margin-bottom:16px;">
        @Icons.Render("shield", 16) <span>As passwords são guardadas <b>cifradas</b> e só são reveladas a pedido. Acesso restrito a administradores e gestores.</span>
    </div>

    <div class="card">
        <table class="tbl">
            <thead><tr><th>Acesso</th><th>Portal</th><th>Nº Proc.</th><th>Utilizador</th><th>Password</th><th>Projeto</th><th></th></tr></thead>
            <tbody>
            @foreach (var c in Model)
            {
                <tr data-id="@c.Id" data-name="@c.Name" data-proc="@c.ProcNumber" data-portal="@c.Portal" data-url="@c.Url" data-username="@c.Username" data-notes="@c.Notes" data-project="@c.ProjectId">
                    <td><div style="font-weight:700;">@c.Name</div>@if (!string.IsNullOrEmpty(c.Url)) { <a href="@(c.Url.StartsWith("http") ? c.Url : "https://" + c.Url)" target="_blank" rel="noopener" class="muted-3" style="font-size:12px;font-weight:600;">@c.Url</a> }</td>
                    <td class="muted" style="font-weight:600;">@(c.Portal ?? "—")</td>
                    <td class="num muted" style="font-weight:600;">@(c.ProcNumber ?? "—")</td>
                    <td style="font-weight:600;font-size:13.5px;">@(c.Username ?? "—")</td>
                    <td>
                        @if (!string.IsNullOrEmpty(c.PasswordEnc))
                        {
                            <span style="display:inline-flex;align-items:center;gap:8px;">
                                <span class="num pc-pw" id="pw-@c.Id" style="font-weight:700;letter-spacing:.08em;">••••••••</span>
                                <button class="icon-btn" type="button" style="width:28px;height:28px;" title="Mostrar/ocultar" onclick="pcReveal(@c.Id, this)">@Icons.Render("eye", 14)</button>
                                <button class="icon-btn" type="button" style="width:28px;height:28px;" title="Copiar" onclick="pcCopy(@c.Id)">@Icons.Render("paperclip", 14)</button>
                            </span>
                        }
                        else { <span class="muted-3">—</span> }
                    </td>
                    <td class="muted" style="font-weight:600;">@(c.Project?.Code ?? "—")</td>
                    <td style="text-align:right;">
                        <div style="display:flex;gap:6px;justify-content:flex-end;">
                            <button class="icon-btn" type="button" style="width:32px;height:32px;" title="Editar" onclick="pcEdit(this.closest('tr'))">@Icons.Render("settings", 15)</button>
                            <form asp-action="Delete" asp-route-id="@c.Id" method="post" style="margin:0;" onsubmit="return confirm('Remover este acesso?')"><button class="icon-btn" type="submit" style="width:32px;height:32px;" title="Remover">@Icons.Render("x", 15)</button></form>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
        @if (Model.Count == 0)
        {
            <div class="empty" style="padding:48px 0;">@Icons.Render("lock", 30)<div style="margin-top:10px;font-weight:700;color:var(--text-2);">Sem acessos guardados</div><div style="margin-top:4px;">Adiciona o primeiro login de portal acima.</div></div>
        }
    </div>
</div>

@* ===== Modal Novo/Editar acesso ===== *@
<div class="modal-overlay" id="pcOv" style="display:none;" onmousedown="if(event.target===this)pcClose()">
    <div class="modal-card" style="width:560px;">
        <div class="modal-head"><div><h3 id="pcTitle">Novo acesso</h3><p>Login de portal para licenciamento</p></div><button class="icon-btn" type="button" style="width:36px;height:36px;" onclick="pcClose()">@Icons.Render("x", 18)</button></div>
        <form asp-action="Save" method="post">
            <input type="hidden" name="id" id="pcId" value="0" />
            <div class="modal-body">
                <div class="fld"><label>Nome do acesso</label><div class="fld__box" style="height:46px;"><input name="name" id="pcName" required placeholder="Ex.: Germano Centro — HOMECEL" /></div></div>
                <div style="display:flex;gap:14px;">
                    <div class="fld" style="flex:1;"><label>Portal / entidade</label><div class="fld__box" style="height:46px;"><input name="portal" id="pcPortal" placeholder="Ex.: CMLisboa" /></div></div>
                    <div class="fld" style="flex:1;"><label>Nº de processo</label><div class="fld__box" style="height:46px;"><input name="procNumber" id="pcProc" placeholder="Ex.: 19_251" /></div></div>
                </div>
                <div class="fld"><label>URL (opcional)</label><div class="fld__box" style="height:46px;"><input name="url" id="pcUrl" placeholder="portal.cm-lisboa.pt" /></div></div>
                <div style="display:flex;gap:14px;">
                    <div class="fld" style="flex:1;"><label>Utilizador</label><div class="fld__box" style="height:46px;"><input name="username" id="pcUsername" autocomplete="off" /></div></div>
                    <div class="fld" style="flex:1;"><label>Password</label><div class="fld__box" style="height:46px;"><input name="password" id="pcPassword" type="password" autocomplete="new-password" placeholder="•••• (em branco = manter)" /></div></div>
                </div>
                <div class="fld"><label>Projeto (opcional)</label><div class="fld__box" style="height:46px;"><select name="projectId" id="pcProject" style="@sel()"><option value="">— sem projeto —</option>@foreach (var p in projects) { <option value="@p.Value">@p.Text</option> }</select></div></div>
                <div class="fld"><label>Notas (opcional)</label><div class="fld__box" style="align-items:flex-start;"><textarea name="notes" id="pcNotes" rows="2" style="border:none;outline:none;background:transparent;flex:1;font-size:14px;resize:vertical;"></textarea></div></div>
            </div>
            <div class="modal-foot"><button class="btn btn-ghost" type="button" onclick="pcClose()">Cancelar</button><button class="btn btn-primary" type="submit">@Icons.Render("check", 15) Guardar</button></div>
        </form>
    </div>
</div>

<form id="afForm" style="display:none;">@Html.AntiForgeryToken()</form>

<script>
    var AF = function () { return document.querySelector('#afForm input[name="__RequestVerificationToken"]').value; };
    function pcOpen() {
        document.getElementById('pcTitle').textContent = 'Novo acesso';
        ['pcId','pcName','pcPortal','pcProc','pcUrl','pcUsername','pcPassword','pcNotes'].forEach(function(k){ document.getElementById(k).value = k==='pcId'?'0':''; });
        document.getElementById('pcProject').value = '';
        document.getElementById('pcPassword').placeholder = '••••';
        document.getElementById('pcOv').style.display = 'grid';
        setTimeout(function(){ document.getElementById('pcName').focus(); }, 20);
    }
    function pcEdit(tr) {
        document.getElementById('pcTitle').textContent = 'Editar acesso';
        document.getElementById('pcId').value = tr.dataset.id;
        document.getElementById('pcName').value = tr.dataset.name || '';
        document.getElementById('pcPortal').value = tr.dataset.portal || '';
        document.getElementById('pcProc').value = tr.dataset.proc || '';
        document.getElementById('pcUrl').value = tr.dataset.url || '';
        document.getElementById('pcUsername').value = tr.dataset.username || '';
        document.getElementById('pcNotes').value = tr.dataset.notes || '';
        document.getElementById('pcProject').value = tr.dataset.project || '';
        document.getElementById('pcPassword').value = '';
        document.getElementById('pcPassword').placeholder = 'em branco = manter a atual';
        document.getElementById('pcOv').style.display = 'grid';
    }
    function pcClose() { document.getElementById('pcOv').style.display = 'none'; }
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape') pcClose(); });

    function pcReveal(id, btn) {
        var el = document.getElementById('pw-' + id);
        if (el.dataset.shown === '1') { el.textContent = '••••••••'; el.dataset.shown = '0'; return; }
        var fd = new FormData(); fd.append('id', id);
        fetch('@Url.Action("Reveal")', { method: 'POST', body: fd, headers: { 'RequestVerificationToken': AF() } })
            .then(function (r) { return r.json(); })
            .then(function (j) { el.textContent = j.ok ? j.password : '(indisponível)'; el.dataset.shown = '1'; })
            .catch(function () { el.textContent = '(erro)'; });
    }
    function pcCopy(id) {
        var fd = new FormData(); fd.append('id', id);
        fetch('@Url.Action("Reveal")', { method: 'POST', body: fd, headers: { 'RequestVerificationToken': AF() } })
            .then(function (r) { return r.json(); })
            .then(function (j) { if (j.ok) { navigator.clipboard.writeText(j.password); if (window.PYToast) PYToast('Password copiada'); } else if (window.PYToast) PYToast('Password indisponível'); });
    }
</script>
