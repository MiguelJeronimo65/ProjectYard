@model ProjectDetailsViewModel
@{
    ViewData["Title"] = Model.Project.Code;
    var p = Model.Project;
}
<div class="content">
    <div class="page-head">
        <div>
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:6px;">
                <a class="badge b-gray" href="@Url.Action("Index")">@Icons.Render("chevD", 12) Projetos</a>
                <span class="badge b-gray">@p.Code</span>
                <span class="badge @Ui.ProjectStatus(p.Status)">@p.Status</span>
                <span title="Saúde" style="width:10px;height:10px;border-radius:99px;background:@Ui.Health(p.Health);"></span>
            </div>
            <h1>@p.Name</h1>
            <p>@(p.Client?.Company ?? "—") · @(p.Type ?? "—") · Gestor: @(p.Manager?.Name ?? "—")</p>
        </div>
        <div class="page-head__actions"><a class="btn btn-ghost" asp-action="Edit" asp-route-id="@p.Id">@Icons.Render("settings", 16) Editar</a></div>
    </div>

    <div class="grid" style="grid-template-columns:repeat(auto-fit,minmax(170px,1fr));margin-bottom:22px;">
        <div class="card card-pad"><div class="muted-3" style="font-weight:700;font-size:11px;text-transform:uppercase;">Honorários</div><div class="num display" style="font-size:22px;">@Ui.Eur(p.Fees)</div></div>
        <div class="card card-pad"><div class="muted-3" style="font-weight:700;font-size:11px;text-transform:uppercase;">Orçamento</div><div class="num display" style="font-size:22px;">@Ui.Eur(p.Budget)</div></div>
        <div class="card card-pad"><div class="muted-3" style="font-weight:700;font-size:11px;text-transform:uppercase;">Gasto</div><div class="num display" style="font-size:22px;">@Ui.Eur(p.Spent)</div></div>
        <div class="card card-pad"><div class="muted-3" style="font-weight:700;font-size:11px;text-transform:uppercase;">Início → Fim</div><div style="font-weight:700;font-size:14px;margin-top:6px;">@Ui.Date(p.StartPlanned) → @Ui.Date(p.EndPlanned)</div></div>
    </div>

    <div class="card" style="margin-bottom:22px;">
        <div class="card-pad card-h"><h3>Fases</h3><span class="sub">@Model.Phases.Count</span></div>
        <table class="tbl">
            <thead><tr><th>Código</th><th>Fase</th><th>Estado</th><th style="width:220px;">Conclusão</th></tr></thead>
            <tbody>
            @foreach (var f in Model.Phases)
            {
                <tr>
                    <td><span class="badge b-gray">@f.Code</span></td>
                    <td style="font-weight:600;">@f.Name</td>
                    <td><span class="badge @Ui.PhaseStatus(f.Status)">@f.Status</span></td>
                    <td>
                        <div style="display:flex;align-items:center;gap:10px;">
                            <div style="flex:1;height:8px;border-radius:99px;background:var(--surface-3);overflow:hidden;"><span style="display:block;height:100%;width:@((f.CompletionPct ?? 0))%;background:var(--grad);"></span></div>
                            <span class="num" style="font-weight:700;font-size:12px;">@((int)(f.CompletionPct ?? 0))%</span>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>

    <div class="grid" style="grid-template-columns:1fr 1fr;align-items:start;">
        <div class="card">
            <div class="card-pad card-h"><h3>Tarefas</h3><span class="sub">@Model.Tasks.Count</span></div>
            <table class="tbl">
                <tbody>
                @foreach (var t in Model.Tasks)
                {
                    var st = Ui.TaskState(t.State);
                    <tr><td style="font-weight:600;">@t.Title</td><td>@(t.Assignee?.Name ?? "—")</td><td><span class="badge @st.cls">@st.label</span></td></tr>
                }
                @if (Model.Tasks.Count == 0) { <tr><td class="muted">Sem tarefas.</td></tr> }
                </tbody>
            </table>
        </div>
        <div class="card">
            <div class="card-pad card-h"><h3>Entregáveis</h3><span class="sub">@Model.Deliverables.Count</span></div>
            <table class="tbl">
                <tbody>
                @foreach (var d in Model.Deliverables)
                {
                    <tr><td style="font-weight:600;">@d.Name <span class="muted-3">@d.Version</span></td><td><span class="badge @Ui.DeliverableStatus(d.Status)">@d.Status</span></td></tr>
                }
                @if (Model.Deliverables.Count == 0) { <tr><td class="muted">Sem entregáveis.</td></tr> }
                </tbody>
            </table>
        </div>
        <div class="card">
            <div class="card-pad card-h"><h3>Milestones de pagamento</h3><span class="sub">@Model.Milestones.Count</span></div>
            <table class="tbl">
                <tbody>
                @foreach (var m in Model.Milestones)
                {
                    <tr><td style="font-weight:600;">@m.Name</td><td class="num" style="text-align:right;">@Ui.Eur(m.Amount)</td><td><span class="badge @Ui.MilestoneStatus(m.Status)">@m.Status</span></td></tr>
                }
                @if (Model.Milestones.Count == 0) { <tr><td class="muted">Sem milestones.</td></tr> }
                </tbody>
            </table>
        </div>
        <div class="card">
            <div class="card-pad card-h"><h3>Riscos</h3><span class="sub">@Model.Risks.Count</span></div>
            <table class="tbl">
                <tbody>
                @foreach (var r in Model.Risks)
                {
                    <tr><td style="font-weight:600;">@r.Title</td><td class="muted-3">P@(r.Probability)·I@(r.Impact)</td><td><span class="badge @Ui.RiskStatus(r.Status)">@r.Status</span></td></tr>
                }
                @if (Model.Risks.Count == 0) { <tr><td class="muted">Sem riscos.</td></tr> }
                </tbody>
            </table>
        </div>
    </div>
</div>
