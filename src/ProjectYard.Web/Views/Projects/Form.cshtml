@model Project
@{
    var editing = Model.Id != 0;
    ViewData["Title"] = editing ? "Editar projeto" : "Novo projeto";
    var clients = (List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)ViewBag.Clients;
    var managers = (List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)ViewBag.Managers;
    var statuses = new[] { "Proposta", "Em curso", "Em risco", "Concluído", "Suspenso" };
    var prios = new[] { "Alta", "Média", "Baixa" };
    var healths = new[] { ("green", "Verde"), ("amber", "Amarelo"), ("red", "Vermelho") };
    string sel() => "border:none;outline:none;background:transparent;flex:1;font-size:14px;";
}
<div class="content">
    <div class="page-head"><div><h1>@(editing ? "Editar projeto" : "Novo projeto")</h1></div></div>
    <form asp-action="@(editing ? "Edit" : "Create")" asp-route-id="@(editing ? Model.Id : (long?)null)" method="post" class="card card-pad" style="max-width:840px;">
        <div asp-validation-summary="ModelOnly" class="login__error"></div>
        @if (editing) { <input type="hidden" asp-for="Id" /> }
        <div class="grid" style="grid-template-columns:1fr 1fr 1fr;gap:16px;">
            <div class="fld"><label asp-for="Code">Código</label><div class="fld__box"><input asp-for="Code" placeholder="PY-121" /></div><span asp-validation-for="Code" class="fld__msg"></span></div>
            <div class="fld" style="grid-column:2/-1;"><label asp-for="Name">Nome</label><div class="fld__box"><input asp-for="Name" /></div><span asp-validation-for="Name" class="fld__msg"></span></div>
            <div class="fld"><label asp-for="ClientId">Cliente</label><div class="fld__box"><select asp-for="ClientId" asp-items="clients" style="@sel()"><option value="">— sem cliente —</option></select></div></div>
            <div class="fld"><label asp-for="ManagerUserId">Gestor</label><div class="fld__box"><select asp-for="ManagerUserId" asp-items="managers" style="@sel()"><option value="">— sem gestor —</option></select></div></div>
            <div class="fld"><label asp-for="Type">Tipo</label><div class="fld__box"><input asp-for="Type" placeholder="Reabilitação urbana…" /></div></div>
            <div class="fld"><label asp-for="Status">Estado</label><div class="fld__box"><select asp-for="Status" style="@sel()">@foreach (var s in statuses){<option value="@s" selected="@(Model.Status == s)">@s</option>}</select></div></div>
            <div class="fld"><label asp-for="Priority">Prioridade</label><div class="fld__box"><select asp-for="Priority" style="@sel()">@foreach (var s in prios){<option value="@s" selected="@(Model.Priority == s)">@s</option>}</select></div></div>
            <div class="fld"><label asp-for="Health">Saúde</label><div class="fld__box"><select asp-for="Health" style="@sel()">@foreach (var (v, l) in healths){<option value="@v" selected="@(Model.Health == v)">@l</option>}</select></div></div>
            <div class="fld"><label asp-for="PhaseCurrent">Fase atual</label><div class="fld__box"><input asp-for="PhaseCurrent" /></div></div>
            <div class="fld"><label asp-for="StartPlanned">Início previsto</label><div class="fld__box"><input asp-for="StartPlanned" type="date" style="@sel()" /></div></div>
            <div class="fld"><label asp-for="EndPlanned">Fim previsto</label><div class="fld__box"><input asp-for="EndPlanned" type="date" style="@sel()" /></div></div>
            <div class="fld"><label asp-for="Fees">Honorários (€)</label><div class="fld__box"><input asp-for="Fees" type="number" step="0.01" style="@sel()" /></div></div>
            <div class="fld"><label asp-for="Budget">Orçamento (€)</label><div class="fld__box"><input asp-for="Budget" type="number" step="0.01" style="@sel()" /></div></div>
            <div class="fld"><label asp-for="Spent">Gasto (€)</label><div class="fld__box"><input asp-for="Spent" type="number" step="0.01" style="@sel()" /></div></div>
            <div class="fld" style="grid-column:1/-1;"><label asp-for="Notes">Observações</label><div class="fld__box" style="align-items:flex-start;"><textarea asp-for="Notes" rows="2" style="border:none;outline:none;background:transparent;flex:1;font-size:14px;resize:vertical;"></textarea></div></div>
        </div>
        <div style="display:flex;gap:10px;margin-top:18px;">
            <button class="btn btn-primary" type="submit">Guardar</button>
            <a class="btn btn-ghost" asp-action="Index">Cancelar</a>
        </div>
    </form>
</div>
