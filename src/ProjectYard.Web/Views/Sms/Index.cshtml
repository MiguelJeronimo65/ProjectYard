@{
    ViewData["Title"] = "SMS";
    var threads = (IEnumerable<dynamic>)ViewBag.Threads;
    var selected = (dynamic?)ViewBag.Selected;
    int enviadas = ViewBag.Enviadas, inbound = ViewBag.Inbound;
    var templates = ProjectYard.Web.Controllers.SmsController.Templates;
    string Hm(DateTime d) => d.Date == DateTime.Today ? d.ToString("HH:mm") : d.Date == DateTime.Today.AddDays(-1) ? "Ontem " + d.ToString("HH:mm") : d.ToString("d MMM HH:mm", System.Globalization.CultureInfo.GetCultureInfo("pt-PT"));
}
<div class="content">
    <div class="page-head">
        <div><h1>SMS</h1><p>Comunicação bidirecional com clientes e entidades · aprovações por resposta</p></div>
        <div class="page-head__actions">
            <button class="btn btn-ghost" type="button">@Icons.Render("settings", 16) Templates</button>
        </div>
    </div>

    <div class="grid cols-4" style="margin-bottom:22px;">
        @foreach (var (icon, col, bg, n, l) in new[]
        {
            ("sms", "var(--info)", "var(--info-soft)", enviadas.ToString(), "Enviadas (mês)"),
            ("check", "var(--success)", "var(--success-soft)", "99%", "Taxa de entrega"),
            ("message", "var(--warning)", "var(--warning-soft)", inbound.ToString(), "Respostas inbound"),
            ("spark", "var(--success)", "var(--success-soft)", "682", "Créditos restantes"),
        })
        {
            <div class="card card-pad" style="display:flex;align-items:center;gap:14px;">
                <div style="width:46px;height:46px;border-radius:12px;background:@bg;color:@col;display:grid;place-items:center;">@Icons.Render(icon, 22)</div>
                <div style="flex:1;"><div class="num" style="font-size:26px;font-weight:700;line-height:1;">@n</div><div class="muted" style="font-size:13px;font-weight:600;">@l</div></div>
            </div>
        }
    </div>

    <div class="card" style="overflow:hidden;display:grid;grid-template-columns:320px 1fr;height:560px;">
        @* lista *@
        <div style="border-right:1px solid var(--border);display:flex;flex-direction:column;min-height:0;">
            <div style="padding:14px;border-bottom:1px solid var(--border);">
                <div class="search" style="width:100%;">@Icons.Render("search", 17)<input placeholder="Procurar conversa…" /></div>
            </div>
            <div style="overflow-y:auto;flex:1;">
                @foreach (var t in threads)
                {
                    bool on = selected != null && (long)selected.ClientId == (long)t.ClientId;
                    <a href="@Url.Action("Index", new { c = (long)t.ClientId })" style="width:100%;display:flex;gap:12px;align-items:center;padding:14px 16px;border-bottom:1px solid var(--border);text-align:left;color:inherit;background:@(on ? "var(--accent-soft)" : "transparent");">
                        @Components.Avatar((string)t.Client.Company, 42, sq: true)
                        <div style="flex:1;min-width:0;">
                            <div style="font-weight:700;font-size:13.5px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@t.Client.Company</div>
                            <div class="muted-3" style="font-size:12.5px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@t.Last.Body</div>
                            <div class="muted-3" style="font-size:11px;font-weight:600;margin-top:2px;">@(t.Project?.Name ?? "—")</div>
                        </div>
                    </a>
                }
            </div>
        </div>

        @* conversa *@
        @if (selected != null)
        {
            <div style="display:flex;flex-direction:column;min-height:0;background:var(--surface-2);">
                <div style="padding:13px 18px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:12px;background:var(--surface);">
                    @Components.Avatar((string)selected.Client.Company, 38, sq: true)
                    <div style="flex:1;">
                        <div style="font-weight:700;font-size:14.5px;">@selected.Client.Company</div>
                        <div class="muted-3" style="font-size:12.5px;font-weight:600;">@selected.Phone · @(selected.Project?.Name ?? "—")</div>
                    </div>
                </div>

                <div style="flex:1;overflow-y:auto;padding:20px;display:flex;flex-direction:column;gap:12px;" id="smsScroll">
                    <div style="text-align:center;"><span class="badge b-gray" style="font-size:11px;">Conversa associada a @(selected.Project?.Name ?? "projeto")</span></div>
                    @foreach (var m in (List<SmsMessage>)selected.Msgs)
                    {
                        var outd = m.Direction == "out";
                        <div style="display:flex;justify-content:@(outd ? "flex-end" : "flex-start");">
                            <div style="max-width:74%;">
                                <div style="padding:11px 15px;border-radius:@(outd ? "16px 16px 4px 16px" : "16px 16px 16px 4px");background:@(outd ? "var(--grad)" : "var(--surface)");color:@(outd ? "#fff" : "var(--text)");border:@(outd ? "none" : "1px solid var(--border)");font-size:13.5px;line-height:1.5;box-shadow:var(--sh-sm);font-weight:@(m.Body.Length < 12 && !outd ? "700" : "500");">@m.Body</div>
                                <div style="display:flex;align-items:center;gap:6px;margin-top:5px;justify-content:@(outd ? "flex-end" : "flex-start");padding-inline:4px;">
                                    @if (m.IsAuto) { <span class="badge b-violet" style="padding:1px 7px;font-size:10px;">Auto</span> }
                                    <span class="muted-3" style="font-size:11px;font-weight:600;">@Hm(m.CreatedAt)</span>
                                    @if (outd) { @Icons.Render("check", 13) }
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div style="border-top:1px solid var(--border);background:var(--surface);padding:14px;">
                    <div style="display:flex;gap:7px;margin-bottom:11px;flex-wrap:wrap;">
                        @foreach (var tp in templates)
                        {
                            <button class="chip" type="button" style="font-size:12px;" onclick="document.getElementById('smsBody').value = @System.Text.Json.JsonSerializer.Serialize(tp.Body)">@Icons.Render("fileText", 13) @tp.Name</button>
                        }
                    </div>
                    <form asp-action="Send" method="post" style="display:flex;gap:10px;align-items:flex-end;margin:0;">
                        <input type="hidden" name="clientId" value="@((long)selected.ClientId)" />
                        <div class="fld__box" style="flex:1;align-items:flex-end;padding:0 14px;">
                            <textarea name="body" id="smsBody" rows="2" required maxlength="160" placeholder="Escreve uma mensagem…" oninput="document.getElementById('smsCount').textContent=this.value.length+'/160'"
                                      style="flex:1;border:none;outline:none;background:transparent;resize:none;padding:12px 0;font-size:14px;font-family:inherit;color:var(--text);"></textarea>
                            <span class="muted-3" id="smsCount" style="font-size:11px;font-weight:600;padding-bottom:12px;">0/160</span>
                        </div>
                        <button class="btn btn-primary" type="submit" style="height:48px;padding:0 18px;">Enviar</button>
                    </form>
                    <div style="display:flex;align-items:center;gap:8px;margin-top:10px;font-size:12px;color:var(--text-3);font-weight:600;">
                        @Icons.Render("spark", 13) Respostas com palavras-chave (APROVO, REJEITO) atualizam aprovações automaticamente.
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="empty" style="display:grid;place-items:center;">@Icons.Render("sms", 34)<div style="margin-top:10px;font-weight:700;color:var(--text-2);">Sem conversas SMS</div></div>
        }
    </div>
</div>
<script>var ss = document.getElementById('smsScroll'); if (ss) ss.scrollTop = ss.scrollHeight;</script>
