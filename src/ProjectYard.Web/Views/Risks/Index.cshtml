@model List<Risk>
@{
    ViewData["Title"] = "Riscos";
    var all = (List<Risk>)ViewBag.All;
    string? fStatus = ViewBag.Estado;
    string? fCat = ViewBag.Cat;
    bool fSev = ViewBag.Criticos;
    var cats = (List<string?>)ViewBag.Cats;
    int Sev(Risk r) => r.Probability * r.Impact;
    (string lbl, string col) SevInfo(int s) => s >= 15 ? ("Crítico", "var(--danger)") : s >= 8 ? ("Elevado", "var(--warning)") : s >= 4 ? ("Moderado", "#caa31a") : ("Baixo", "var(--success)");
    string SevHex(int s) => s >= 15 ? "#d65151" : s >= 8 ? "#e0922a" : s >= 4 ? "#caa31a" : "#1f9d6b";
    string CellBg(int s) => s >= 15 ? "#d6515122" : s >= 8 ? "#e0922a22" : s >= 4 ? "#caa31a1c" : "#1f9d6b1a";
    string CellBd(int s) => s >= 15 ? "#d6515140" : s >= 8 ? "#e0922a40" : s >= 4 ? "#caa31a35" : "#1f9d6b30";
    string StatusTag(Risk r) => r.Status == "Mitigado" ? "b-green" : r.Status == "Monitorizado" ? "b-blue" : r.Status == "Fechado" ? "b-gray" : (Sev(r) >= 15 ? "b-red" : "b-amber");
    int criticosN = all.Count(r => Sev(r) >= 15);
    int abertosN = all.Count(r => r.Status == "Aberto");
    int monitN = all.Count(r => r.Status == "Monitorizado");
    int mitigN = all.Count(r => r.Status == "Mitigado");
    int extraN = (string.IsNullOrEmpty(fStatus) ? 0 : 1) + (string.IsNullOrEmpty(fCat) ? 0 : 1) + (fSev ? 1 : 0);
    string Q(string? estado = null, string? cat = null, bool? criticos = null)
        => Url.Action("Index", new { estado = estado ?? fStatus, cat = cat ?? fCat, criticos = (criticos ?? fSev) ? "true" : null })!;
}
<div class="content">
    <div class="page-head">
        <div><h1>Riscos &amp; bloqueios</h1><p>Registo de riscos com probabilidade, impacto e plano de mitigação</p></div>
        <div class="page-head__actions">
            <button class="btn btn-ghost" type="button">@Icons.Render("download", 16) Exportar registo</button>
            <a class="btn btn-primary" asp-action="Create">@Icons.Render("plus", 16) Registar risco</a>
        </div>
    </div>

    @* Mini-summaries clicáveis (filtros) *@
    <div class="grid cols-4" style="margin-bottom:22px;">
        <a class="card card-pad rise" href="@Q(criticos: !fSev)" style="display:flex;align-items:center;gap:13px;color:inherit;@(fSev ? "border-color:var(--danger);" : "")">
            <div style="width:42px;height:42px;border-radius:11px;background:var(--danger-soft);color:var(--danger);display:grid;place-items:center;">@Icons.Render("alert", 21)</div>
            <div><div class="num display" style="font-size:24px;font-weight:700;">@criticosN</div><div class="muted-3" style="font-size:12.5px;font-weight:600;">Riscos críticos</div></div>
        </a>
        <a class="card card-pad rise" href="@Url.Action("Index", new { estado = fStatus == "Aberto" ? null : "Aberto", cat = fCat, criticos = fSev ? "true" : null })" style="display:flex;align-items:center;gap:13px;color:inherit;@(fStatus == "Aberto" ? "border-color:var(--warning);" : "")">
            <div style="width:42px;height:42px;border-radius:11px;background:var(--warning-soft);color:var(--warning);display:grid;place-items:center;">@Icons.Render("clock", 21)</div>
            <div><div class="num display" style="font-size:24px;font-weight:700;">@abertosN</div><div class="muted-3" style="font-size:12.5px;font-weight:600;">Riscos abertos</div></div>
        </a>
        <a class="card card-pad rise" href="@Url.Action("Index", new { estado = fStatus == "Monitorizado" ? null : "Monitorizado", cat = fCat, criticos = fSev ? "true" : null })" style="display:flex;align-items:center;gap:13px;color:inherit;@(fStatus == "Monitorizado" ? "border-color:var(--info);" : "")">
            <div style="width:42px;height:42px;border-radius:11px;background:var(--info-soft);color:var(--info);display:grid;place-items:center;">@Icons.Render("eye", 21)</div>
            <div><div class="num display" style="font-size:24px;font-weight:700;">@monitN</div><div class="muted-3" style="font-size:12.5px;font-weight:600;">Monitorizados</div></div>
        </a>
        <a class="card card-pad rise" href="@Url.Action("Index", new { estado = fStatus == "Mitigado" ? null : "Mitigado", cat = fCat, criticos = fSev ? "true" : null })" style="display:flex;align-items:center;gap:13px;color:inherit;@(fStatus == "Mitigado" ? "border-color:var(--success);" : "")">
            <div style="width:42px;height:42px;border-radius:11px;background:var(--success-soft);color:var(--success);display:grid;place-items:center;">@Icons.Render("check", 21)</div>
            <div><div class="num display" style="font-size:24px;font-weight:700;">@mitigN</div><div class="muted-3" style="font-size:12.5px;font-weight:600;">Mitigados</div></div>
        </a>
    </div>

    <div class="grid" style="grid-template-columns:1fr 1.3fr;align-items:start;margin-bottom:22px;">
        @* Matriz prob × impacto *@
        <div class="card card-pad">
            <div class="card-h"><div><h3>Matriz de risco</h3><span class="sub">Probabilidade × Impacto</span></div></div>
            <div style="display:flex;gap:10px;">
                <div style="display:flex;align-items:center;">
                    <span style="writing-mode:vertical-rl;transform:rotate(180deg);font-size:11.5px;font-weight:700;color:var(--text-3);letter-spacing:0.04em;text-transform:uppercase;">Probabilidade →</span>
                </div>
                <div style="flex:1;">
                    <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:6px;">
                        @foreach (var p in new[] { 5, 4, 3, 2, 1 })
                        {
                            foreach (var im in new[] { 1, 2, 3, 4, 5 })
                            {
                                var s = p * im;
                                var here = all.Where(r => r.Probability == p && r.Impact == im).ToList();
                                <div style="aspect-ratio:1;border-radius:9px;background:@CellBg(s);border:1px solid @CellBd(s);display:grid;place-items:center;position:relative;">
                                    @foreach (var r in here)
                                    {
                                        <a href="@Url.Action("Edit", new { id = r.Id })" title="@r.Title"
                                           style="width:30px;height:30px;border-radius:99px;background:@SevHex(s);color:#fff;display:grid;place-items:center;font-weight:800;font-size:12px;box-shadow:var(--sh-sm);border:2px solid #fff;">@(r.Project?.Code?.Split('-').LastOrDefault()?.TrimStart('1') ?? "·")</a>
                                    }
                                </div>
                            }
                        }
                    </div>
                    <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:6px;margin-top:7px;">
                        @for (int n = 1; n <= 5; n++) { <div style="text-align:center;font-size:11.5px;font-weight:700;color:var(--text-3);">@n</div> }
                    </div>
                    <div style="text-align:center;font-size:11.5px;font-weight:700;color:var(--text-3);letter-spacing:0.04em;text-transform:uppercase;margin-top:5px;">Impacto →</div>
                </div>
            </div>
            <div style="display:flex;gap:14px;margin-top:16px;flex-wrap:wrap;">
                @foreach (var (l, c) in new[] { ("Baixo", "var(--success)"), ("Moderado", "#caa31a"), ("Elevado", "var(--warning)"), ("Crítico", "var(--danger)") })
                {
                    <div style="display:flex;align-items:center;gap:6px;font-size:12px;font-weight:600;color:var(--text-2);"><span style="width:11px;height:11px;border-radius:4px;background:@c;"></span>@l</div>
                }
            </div>
        </div>

        @* Riscos prioritários *@
        <div class="card card-pad">
            <div class="card-h"><div><h3>Riscos prioritários</h3><span class="sub">Ordenados por severidade</span></div></div>
            <div style="display:flex;flex-direction:column;gap:11px;">
                @foreach (var r in all.OrderByDescending(Sev).Take(4))
                {
                    var s = Sev(r); var (lbl, col) = SevInfo(s);
                    <a href="@Url.Action("Edit", new { id = r.Id })" style="display:flex;align-items:center;gap:13px;padding:13px;color:inherit;border:1px solid var(--border);border-radius:var(--r-sm);">
                        <div style="width:40px;height:40px;border-radius:10px;background:@(SevHex(s))1f;color:@col;display:grid;place-items:center;flex-shrink:0;font-weight:800;font-size:14px;">@s</div>
                        <div style="flex:1;min-width:0;">
                            <div style="font-weight:700;font-size:13.5px;">@r.Title</div>
                            <div class="muted-3" style="font-size:12px;font-weight:600;">@(r.Project?.Name ?? "—") · @(r.Category ?? "—")</div>
                        </div>
                        <span class="badge @StatusTag(r)">@lbl</span>
                    </a>
                }
            </div>
        </div>
    </div>

    @* Registo *@
    <div class="card">
        <div class="card-pad" style="padding-bottom:6px;">
            <div class="card-h">
                <div><h3>Registo de riscos</h3><span class="sub">@Model.Count de @all.Count riscos · todos os projetos</span></div>
                <details style="position:relative;" class="card-h more">
                    <summary class="btn btn-ghost btn-sm" style="list-style:none;cursor:pointer;@(extraN > 0 ? "border-color:var(--accent);color:var(--accent-700);" : "")">@Icons.Render("filter", 14) Filtrar@(extraN > 0 ? " · " + extraN : "")</summary>
                    <div class="flt-pop" style="left:auto;right:0;min-width:210px;">
                        <div class="ws-menu__lbl">Estado</div>
                        <a class="flt-opt @(string.IsNullOrEmpty(fStatus) ? "on" : "")" href="@Url.Action("Index", new { cat = fCat, criticos = fSev ? "true" : null })">Todos</a>
                        @foreach (var st in new[] { "Aberto", "Monitorizado", "Mitigado", "Fechado" })
                        {
                            <a class="flt-opt @(fStatus == st ? "on" : "")" href="@Q(estado: st)">@st</a>
                        }
                        <div class="divider" style="margin:6px 0;"></div>
                        <div class="ws-menu__lbl">Categoria</div>
                        <a class="flt-opt @(string.IsNullOrEmpty(fCat) ? "on" : "")" href="@Url.Action("Index", new { estado = fStatus, criticos = fSev ? "true" : null })">Todas</a>
                        @foreach (var c in cats)
                        {
                            <a class="flt-opt @(fCat == c ? "on" : "")" href="@Q(cat: c)">@c</a>
                        }
                        @if (extraN > 0)
                        {
                            <div class="divider" style="margin:6px 0;"></div>
                            <a class="flt-opt" style="color:var(--danger);" href="@Url.Action("Index")">Limpar filtros</a>
                        }
                    </div>
                </details>
            </div>
        </div>
        <table class="tbl">
            <thead><tr><th>Risco</th><th>Projeto</th><th>Categoria</th><th>Prob.</th><th>Impacto</th><th>Severidade</th><th>Responsável</th><th>Estado</th><th></th></tr></thead>
            <tbody>
            @foreach (var r in Model)
            {
                var s = Sev(r); var (lbl, col) = SevInfo(s);
                <tr class="row-click" onclick="location.href='@Url.Action("Edit", new { id = r.Id })'">
                    <td style="max-width:280px;">
                        <div style="font-weight:700;">@r.Title</div>
                        <div class="muted-3" style="font-size:12px;font-weight:600;margin-top:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:260px;">@(r.Mitigation ?? "")</div>
                    </td>
                    <td class="muted" style="font-weight:600;">@(r.Project?.Name ?? "—")</td>
                    <td><span class="badge b-gray">@(r.Category ?? "—")</span></td>
                    <td class="num" style="font-weight:700;">@r.Probability</td>
                    <td class="num" style="font-weight:700;">@r.Impact</td>
                    <td><span style="display:inline-flex;align-items:center;gap:8px;font-weight:700;font-size:13px;color:@col;"><span style="width:26px;height:26px;border-radius:7px;background:@(SevHex(s))1f;display:grid;place-items:center;font-size:12px;font-weight:800;">@s</span>@lbl</span></td>
                    <td><div style="display:flex;align-items:center;gap:8px;">@Components.Avatar(r.Owner?.Name, 28)<span style="font-weight:600;font-size:13px;">@(r.Owner?.Name.Split(' ').FirstOrDefault() ?? "—")</span></div></td>
                    <td><span class="badge @StatusTag(r)"><span class="bdot"></span>@r.Status</span></td>
                    <td onclick="event.stopPropagation();">
                        <form asp-action="Delete" asp-route-id="@r.Id" method="post" style="display:inline;" onsubmit="return confirm('Eliminar este risco?');">
                            <button class="icon-btn" type="submit" style="width:32px;height:32px;color:var(--danger);" title="Eliminar">@Icons.Render("x", 15)</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
        @if (Model.Count == 0)
        {
            <div class="empty" style="padding:40px 0;">@Icons.Render("alert", 30)<div style="margin-top:10px;font-weight:700;color:var(--text-2);">Sem riscos com estes filtros</div></div>
        }
    </div>
</div>
