@{ ViewData["Title"] = "Cronograma"; }
<link rel="stylesheet" href="https://cdn.dhtmlx.com/gantt/edge/dhtmlxgantt.css" />
<link rel="stylesheet" href="~/css/gantt.css" asp-append-version="true" />
<div class="content">
    <div class="page-head">
        <div><h1>Cronograma</h1><p>Fases dos projetos · previsto vs real · dependências (DHTMLX Gantt).</p></div>
        <div class="page-head__actions">
            <div class="chip-row" style="display:flex;gap:6px;">
                <button type="button" class="chip" onclick="setZoom('Semana')">Semana</button>
                <button type="button" class="chip active" onclick="setZoom('Mês')">Mês</button>
                <button type="button" class="chip" onclick="setZoom('Trimestre')">Trimestre</button>
                <button type="button" class="chip" onclick="setZoom('Ano')">Ano</button>
            </div>
        </div>
    </div>
    <div style="display:flex;gap:6px;margin-bottom:14px;flex-wrap:wrap;">
        <button type="button" class="chip active" data-f="" onclick="setGanttFilter(this,'')">Todas</button>
        <button type="button" class="chip" data-f="curso" onclick="setGanttFilter(this,'curso')">Em curso</button>
        <button type="button" class="chip" data-f="done" onclick="setGanttFilter(this,'done')">Concluídas</button>
        <button type="button" class="chip" data-f="init" onclick="setGanttFilter(this,'init')">Por iniciar</button>
        <button type="button" class="chip" data-f="late" onclick="setGanttFilter(this,'late')">Em atraso</button>
    </div>
    <div class="card" style="padding:0;overflow:hidden;">
        <div id="gantt_here" style="width:100%;height:640px;"></div>
    </div>
</div>

<script src="https://cdn.dhtmlx.com/gantt/edge/dhtmlxgantt.js"></script>
<script>
    gantt.config.date_format = "%Y-%m-%d";
    gantt.config.start_date = new Date(2025, 0, 1);
    gantt.config.end_date = new Date(2028, 0, 1);
    gantt.config.readonly = true;

    gantt.config.columns = [
        { name: "text", label: "Projeto / Fase", tree: true, width: 240, resize: true },
        { name: "progress", label: "%", align: "center", width: 52,
          template: t => (t.type === "project" || t.status === "Em curso") ? Math.round((t.progress || 0) * 100) + "%" : "" },
    ];

    gantt.ext.zoom.init({ levels: [
        { name: "Semana", scale_height: 62, min_column_width: 30, scales: [
            { unit: "year", step: 1, format: "%Y" }, { unit: "month", step: 1, format: "%M" },
            { unit: "week", step: 1, format: d => "S" + gantt.date.getISOWeek(d) } ] },
        { name: "Mês", scale_height: 52, min_column_width: 72, scales: [
            { unit: "year", step: 1, format: "%Y" }, { unit: "month", step: 1, format: "%M" } ] },
        { name: "Trimestre", scale_height: 52, min_column_width: 92, scales: [
            { unit: "year", step: 1, format: "%Y" }, { unit: "quarter", step: 1, format: d => "T" + (Math.floor(d.getMonth() / 3) + 1) } ] },
        { name: "Ano", scale_height: 40, min_column_width: 120, scales: [ { unit: "year", step: 1, format: "%Y" } ] },
    ] });

    gantt.plugins({ marker: true, tooltip: true });

    gantt.templates.task_class = (s, e, t) =>
        t.type === "project" ? "py-project" : t.status === "Concluída" ? "py-done" : t.status === "Em curso" ? "py-doing" : "py-todo";
    gantt.templates.task_text = (s, e, t) => t.status === "Em curso" ? Math.round((t.progress || 0) * 100) + "%" : "";
    gantt.templates.tooltip_text = (s, e, t) =>
        `<b>${t.text}</b><br/>Estado: ${t.status || "—"}<br/>Previsto: ${t.planned_start || "—"} → ${t.planned_end || "—"}`;

    // Baseline = previsto (barra fina por baixo)
    gantt.addTaskLayer(t => {
        if (!t.planned_start) return false;
        const sX = gantt.posFromDate(gantt.date.parseDate(t.planned_start, "%Y-%m-%d"));
        const eX = gantt.posFromDate(gantt.date.parseDate(t.planned_end, "%Y-%m-%d"));
        const el = document.createElement("div");
        el.className = "py-baseline";
        el.style.left = sX + "px";
        el.style.width = Math.max(0, eX - sX) + "px";
        el.style.top = gantt.getTaskTop(t.id) + gantt.config.task_height + 4 + "px";
        return el;
    });

    let activeFilter = "";
    gantt.attachEvent("onBeforeTaskDisplay", (id, t) => {
        if (t.type === "project" || !activeFilter) return true;
        switch (activeFilter) {
            case "done": return t.status === "Concluída";
            case "curso": return t.status === "Em curso";
            case "init": return t.status === "Por iniciar";
            case "late": return t.status !== "Concluída" && gantt.date.parseDate(t.planned_end, "%Y-%m-%d") < new Date(2026, 5, 8);
            default: return true;
        }
    });

    gantt.init("gantt_here");
    gantt.load("@Url.Action("Data", "Gantt")");
    gantt.ext.zoom.setLevel("Mês");
    gantt.addMarker({ start_date: new Date(2026, 5, 8), css: "today-line", text: "Hoje", title: "8 Jun 2026" });
    gantt.showDate(new Date(2026, 5, 8));

    function setZoom(level) {
        gantt.ext.zoom.setLevel(level);
        document.querySelectorAll('.chip-row .chip').forEach(c => c.classList.toggle('active', c.textContent === level));
    }
    function setGanttFilter(btn, kind) {
        activeFilter = kind;
        btn.parentElement.querySelectorAll('.chip').forEach(c => c.classList.toggle('active', c === btn));
        gantt.render();
    }
</script>
