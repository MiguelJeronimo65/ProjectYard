@model ComplianceViewModel
@{
    ViewData["Title"] = "Conformidade RGPD";
    var bases = ProjectYard.Web.Controllers.ComplianceController.Bases;
    string Ago(DateTime? d)
    {
        if (d is null) return "—";
        var span = DateTime.Now - d.Value;
        if (span.TotalMinutes < 60) return "há " + Math.Max(1, (int)span.TotalMinutes) + " min";
        if (span.TotalHours < 24) return "há " + (int)span.TotalHours + " h";
        if (span.TotalDays < 2) return "ontem";
        return "há " + (int)span.TotalDays + " dias";
    }
    string Retention(ComplianceConvo c) => c.RetentionMonths is { } m ? $"Retém {m} meses" : "Indefinida";
}
<div class="content">
    <div class="breadcrumb"><a href="@Url.Action("Index","Workspaces")">Plataforma</a>@Icons.Render("chevR", 13)<a>Conformidade RGPD</a></div>
    <div class="page-head">
        <div>
            <h1>Conformidade RGPD — Chat</h1>
            <p>Supervisão transversal das comunicações · princípio da minimização de dados</p>
        </div>
        <div class="page-head__actions">
            <button class="btn btn-ghost" type="button">@Icons.Render("download", 16) Exportar registo</button>
        </div>
    </div>

    @* Princípio de minimização *@
    <div class="card card-pad" style="display:flex;align-items:flex-start;gap:16px;margin-bottom:22px;background:var(--info-soft);border-color:transparent;">
        <div style="width:46px;height:46px;border-radius:12px;background:var(--info);color:#fff;display:grid;place-items:center;flex-shrink:0;">@Icons.Render("shield", 24)</div>
        <div style="flex:1;min-width:0;">
            <div style="font-weight:700;font-size:15px;font-family:var(--font-display);">Por omissão, só metadados.</div>
            <div class="muted" style="font-size:13.5px;font-weight:600;line-height:1.6;margin-top:3px;max-width:760px;">
                O conteúdo das mensagens é privado e cifrado em repouso — nem a plataforma o lê por rotina. Só ficam visíveis
                volume e atividade. O acesso a conteúdo exige <b>base legal</b> e <b>justificação</b>, e é registado de forma imutável no
                <b>ChatComplianceAccessLog</b>.
            </div>
        </div>
        <span style="display:inline-flex;align-items:center;gap:6px;padding:5px 11px;border-radius:var(--r-pill);background:var(--surface);color:var(--text-2);font-size:12px;font-weight:700;white-space:nowrap;flex-shrink:0;">@Icons.Render("lock", 13) Cifrado em repouso</span>
    </div>

    @* KPIs *@
    <div class="grid cols-4" style="margin-bottom:22px;">
        <div class="card card-pad stat rise">
            <div class="stat__top"><div class="stat__icon" style="background:var(--primary-soft);color:var(--primary);">@Icons.Render("message", 23)</div></div>
            <div><div class="stat__val">@Model.Convos.Count</div><div class="stat__label">Conversas monitorizadas</div></div>
            <div class="muted-3" style="font-size:12.5px;font-weight:600;margin-top:-4px;">@Model.Channels canais · @Model.Directs diretas</div>
        </div>
        <div class="card card-pad stat rise">
            <div class="stat__top"><div class="stat__icon" style="background:var(--accent-soft);color:var(--accent-700);">@Icons.Render("layers", 23)</div></div>
            <div><div class="stat__val">@Model.TotalMsgs30.ToString("#,##0", System.Globalization.CultureInfo.GetCultureInfo("pt-PT"))</div><div class="stat__label">Mensagens (30 dias)</div></div>
            <div class="muted-3" style="font-size:12.5px;font-weight:600;margin-top:-4px;">Volume agregado · sem conteúdo</div>
        </div>
        <div class="card card-pad stat rise">
            <div class="stat__top"><div class="stat__icon" style="background:var(--info-soft);color:var(--info);">@Icons.Render("eye", 23)</div></div>
            <div><div class="stat__val">@Model.Log.Count</div><div class="stat__label">Acessos a conteúdo</div></div>
            <div class="muted-3" style="font-size:12.5px;font-weight:600;margin-top:-4px;">Trimestre · @Model.ActiveAccess ativo@(Model.ActiveAccess == 1 ? "" : "s")</div>
        </div>
        <div class="card card-pad stat rise">
            <div class="stat__top"><div class="stat__icon" style="background:var(--warning-soft);color:var(--warning);">@Icons.Render("lock", 23)</div></div>
            <div><div class="stat__val">@Model.Holds</div><div class="stat__label">Retenção suspensa</div></div>
            <div class="muted-3" style="font-size:12.5px;font-weight:600;margin-top:-4px;">Preservação de prova / litígio</div>
        </div>
    </div>

    <div class="card card-pad">
        @* Tabs *@
        <div style="display:flex;gap:4px;border-bottom:1px solid var(--border);margin-bottom:18px;">
            <a href="@Url.Action("Index", new { ws = Model.Ws == "Todos" ? null : Model.Ws })" style="padding:12px 16px;font-weight:700;font-size:14px;margin-bottom:-1px;color:@(Model.Tab == "metadados" ? "var(--primary-700)" : "var(--text-2)");border-bottom:2px solid @(Model.Tab == "metadados" ? "var(--accent)" : "transparent");">Metadados</a>
            <a href="@Url.Action("Index", new { tab = "acessos" })" style="padding:12px 16px;font-weight:700;font-size:14px;margin-bottom:-1px;color:@(Model.Tab == "acessos" ? "var(--primary-700)" : "var(--text-2)");border-bottom:2px solid @(Model.Tab == "acessos" ? "var(--accent)" : "transparent");">Registo de acessos <span class="badge b-navy" style="margin-left:8px;padding:1px 7px;font-size:10.5px;">@Model.Log.Count</span></a>
        </div>

        @if (Model.Tab == "metadados")
        {
            <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;margin-bottom:6px;">
                <div style="display:flex;gap:4px;flex-wrap:wrap;flex:1;min-width:0;">
                    <a href="@Url.Action("Index")" style="padding:7px 13px;border-radius:var(--r-pill);font-weight:700;font-size:13px;white-space:nowrap;@(Model.Ws == "Todos" ? "background:var(--navy);color:#fff;" : "color:var(--text-2);")">Todos</a>
                    @foreach (var t in Model.Tenants)
                    {
                        <a href="@Url.Action("Index", new { ws = t })" style="padding:7px 13px;border-radius:var(--r-pill);font-weight:700;font-size:13px;white-space:nowrap;@(Model.Ws == t ? "background:var(--navy);color:#fff;" : "color:var(--text-2);")">@t</a>
                    }
                </div>
            </div>

            <div style="overflow-x:auto;">
                <table class="tbl" style="min-width:920px;">
                    <thead><tr><th>Workspace</th><th>Conversa</th><th>Participantes</th><th style="text-align:right;">Atividade (30 d)</th><th>Conteúdo</th><th>Última atividade</th><th></th></tr></thead>
                    <tbody>
                    @foreach (var c in Model.Convos)
                    {
                        <tr>
                            <td>
                                <div style="display:flex;align-items:center;gap:10px;">
                                    <span class="avatar sq" style="width:30px;height:30px;background:@(c.TenantColor ?? "#2c3e51");font-size:11px;">@Components.Initials(c.TenantName)</span>
                                    <span style="font-weight:600;font-size:13.5px;">@c.TenantName</span>
                                </div>
                            </td>
                            <td>
                                <div style="display:flex;align-items:center;gap:11px;">
                                    @if (c.Type == "channel")
                                    {
                                        <div style="width:38px;height:38px;border-radius:11px;background:@(c.TenantColor ?? "#6a5af9")22;color:@(c.TenantColor ?? "#6a5af9");display:grid;place-items:center;font-weight:800;font-size:17px;flex-shrink:0;font-family:var(--font-display);">#</div>
                                    }
                                    else
                                    {
                                        <div style="width:38px;height:38px;border-radius:11px;background:var(--surface-3);color:var(--text-2);display:grid;place-items:center;flex-shrink:0;">@Icons.Render("lock", 16)</div>
                                    }
                                    <div style="min-width:0;">
                                        <div style="font-weight:700;font-size:13.5px;">@(c.Type == "channel" ? "#" + c.Name : "Conversa direta")</div>
                                        <div class="muted-3" style="font-size:11.5px;font-weight:600;display:flex;align-items:center;gap:6px;margin-top:2px;">
                                            @(c.Type == "channel" ? (c.ProjectName ?? "—") : "Privada")
                                            <span style="opacity:.5;">·</span>
                                            @if (c.LegalHold)
                                            {
                                                <span style="color:var(--warning);font-weight:700;display:inline-flex;align-items:center;gap:3px;">@Icons.Render("lock", 10) Legal hold</span>
                                            }
                                            else
                                            {
                                                <span>@Retention(c)</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div style="display:flex;align-items:center;gap:9px;">
                                    @Components.AvStack(c.Participants, 3, 26)
                                    <span class="muted-3" style="font-size:12.5px;font-weight:700;">@c.Participants.Count</span>
                                </div>
                            </td>
                            <td style="text-align:right;">
                                <div class="num" style="font-weight:700;font-size:14.5px;">@c.Msgs30</div>
                                <div class="muted-3" style="font-size:11.5px;font-weight:600;">@c.Attachments anexo@(c.Attachments == 1 ? "" : "s")</div>
                            </td>
                            <td><span style="display:inline-flex;align-items:center;gap:6px;padding:5px 11px;border-radius:var(--r-pill);background:var(--surface-3);color:var(--text-2);font-size:12px;font-weight:700;white-space:nowrap;">@Icons.Render("lock", 12) Protegido</span></td>
                            <td><span class="muted-3" style="font-size:13px;font-weight:600;">@Ago(c.LastActivity)</span></td>
                            <td style="text-align:right;">
                                <button class="btn btn-soft btn-sm" type="button"
                                        onclick="openAccess(@c.Id, '@(c.Type == "channel" ? "#" + c.Name : "Conversa direta")', '@c.TenantName', @c.Participants.Count, @c.Msgs30)">
                                    @Icons.Render("eye", 14) Aceder
                                </button>
                            </td>
                        </tr>
                    }
                    @if (Model.Convos.Count == 0)
                    {
                        <tr><td colspan="7"><div class="empty" style="padding:32px 20px;">@Icons.Render("search", 26)<div style="margin-top:8px;font-weight:700;color:var(--text-2);">Sem conversas para este filtro.</div></div></td></tr>
                    }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="muted" style="font-size:13px;font-weight:600;margin-bottom:14px;display:flex;align-items:center;gap:7px;">
                @Icons.Render("shield", 14) Trilho de auditoria imutável de todos os acessos a conteúdo privado. Conservado 5 anos.
            </div>
            <div style="overflow-x:auto;">
                <table class="tbl" style="min-width:960px;">
                    <thead><tr><th>Registo</th><th>Quando</th><th>Acedido por</th><th>Workspace · conversa</th><th>Base legal</th><th>Âmbito</th><th>Estado</th></tr></thead>
                    <tbody>
                    @foreach (var l in Model.Log)
                    {
                        <tr>
                            <td><span class="num" style="font-weight:700;font-size:12.5px;color:var(--text-2);">@l.Ref</span></td>
                            <td><span style="font-weight:600;font-size:13px;">@Ui.Date(l.CreatedAt)</span></td>
                            <td>
                                <div style="display:flex;align-items:center;gap:9px;">
                                    @Components.Avatar(l.AccessedByUser?.Name, 30)
                                    <div style="min-width:0;">
                                        <div style="font-weight:700;font-size:13px;">@(l.AccessedByUser?.Name ?? "—")</div>
                                        <div class="muted-3" style="font-size:11px;font-weight:600;">@((l.AccessedByUser?.Funcao ?? "").Contains("DPO") ? "DPO" : "Superadmin")</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div style="font-weight:700;font-size:13px;">@(l.TargetTenant?.Name ?? "—")</div>
                                <div class="muted-3" style="font-size:11.5px;font-weight:600;max-width:260px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@l.Reason</div>
                            </td>
                            <td style="max-width:220px;">
                                <div style="font-weight:600;font-size:12.5px;">@l.LegalBasis</div>
                                <div class="muted-3" style="font-size:11px;font-weight:600;">@(l.LegalBasisRef ?? "")</div>
                            </td>
                            <td><span class="muted-3" style="font-size:12.5px;font-weight:600;">@(l.Scope ?? "—")</span></td>
                            <td><span class="badge @(l.State == "Ativo" ? "b-amber" : "b-green")">@l.State</span></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <div class="muted-3" style="font-size:12.5px;font-weight:600;margin-top:18px;display:flex;align-items:center;gap:7px;">
        @Icons.Render("shield", 14) Acesso de plataforma · todas as ações nesta área são auditadas e os titulares podem ser notificados nos termos do RGPD.
    </div>
</div>

@* ===== Modal Aceder a conteúdo privado ===== *@
<div class="modal-overlay" id="accOv" style="display:none;" onmousedown="if(event.target===this)this.style.display='none'">
    <div class="modal-card" style="width:540px;">
        <div class="modal-head">
            <div><h3>Aceder a conteúdo privado</h3><p>Esta ação fica registada no ChatComplianceAccessLog</p></div>
            <button class="icon-btn" type="button" style="width:36px;height:36px;" onclick="document.getElementById('accOv').style.display='none'">@Icons.Render("x", 18)</button>
        </div>
        <form asp-action="Access" method="post">
            <div class="modal-body">
                <input type="hidden" name="channelId" id="accChannel" />
                <div style="display:flex;gap:12px;padding:13px;border-radius:var(--r-sm);background:var(--warning-soft);margin-bottom:18px;">
                    @Icons.Render("alert", 19)
                    <div style="font-size:12.5px;font-weight:600;line-height:1.55;color:var(--text-2);">
                        Está prestes a aceder a comunicações privadas de outro workspace. O acesso é proporcional, limitado ao necessário e <b>auditável</b>. O uso indevido tem consequências disciplinares e legais.
                    </div>
                </div>
                <div style="display:flex;align-items:center;gap:12px;padding:12px;border-radius:var(--r-sm);border:1px solid var(--border);margin-bottom:18px;">
                    <div style="width:40px;height:40px;border-radius:11px;background:var(--surface-3);color:var(--text-2);display:grid;place-items:center;flex-shrink:0;">@Icons.Render("lock", 17)</div>
                    <div style="flex:1;min-width:0;">
                        <div style="font-weight:700;font-size:14px;" id="accName"></div>
                        <div class="muted-3" style="font-size:12px;font-weight:600;" id="accMeta"></div>
                    </div>
                </div>
                <div class="fld">
                    <label>Base legal do acesso</label>
                    <div class="fld__box" style="height:46px;">
                        <select name="basis" required style="flex:1;border:none;outline:none;background:transparent;font-size:14px;font-weight:600;color:var(--text);">
                            <option value="" disabled selected>Selecionar fundamento…</option>
                            @foreach (var b in bases) { <option value="@b.Id">@b.Label — @b.Ref</option> }
                        </select>
                    </div>
                </div>
                <div class="fld">
                    <label>Justificação</label>
                    <div class="fld__box" style="align-items:stretch;padding:11px 13px;">
                        <textarea name="reason" rows="3" minlength="12" required placeholder="Descreva o motivo concreto e o âmbito do acesso (ex.: pedido, processo, período abrangido)…" style="flex:1;border:none;outline:none;background:transparent;resize:vertical;font-size:14px;font-family:inherit;color:var(--text);line-height:1.5;"></textarea>
                    </div>
                    <div class="muted-3" style="font-size:12px;font-weight:600;margin-top:5px;">Mínimo de 12 caracteres · fica anexada ao registo de auditoria</div>
                </div>
                <label style="display:flex;align-items:flex-start;gap:10px;cursor:pointer;padding:4px 0;">
                    <input type="checkbox" required style="width:18px;height:18px;accent-color:var(--accent);margin-top:1px;flex-shrink:0;" />
                    <span style="font-size:12.5px;font-weight:600;color:var(--text-2);line-height:1.5;">Confirmo que o acesso é necessário e proporcional ao fundamento indicado e autorizo o seu registo no trilho de auditoria.</span>
                </label>
            </div>
            <div class="modal-foot">
                <button class="btn btn-ghost" type="button" onclick="document.getElementById('accOv').style.display='none'">Cancelar</button>
                <button class="btn btn-primary" type="submit">@Icons.Render("eye", 15) Confirmar e registar acesso</button>
            </div>
        </form>
    </div>
</div>

@* ===== Modal conteúdo revelado (mensagens reais do canal) ===== *@
@if (Model.Reveal != null && Model.RevealEntry != null)
{
    <div class="modal-overlay" id="revOv" onmousedown="if(event.target===this)this.style.display='none'">
        <div class="modal-card modal-card--bare" style="width:580px;">
            <div style="background:var(--navy);color:#fff;padding:16px 22px;">
                <div style="display:flex;align-items:center;gap:11px;">
                    <div style="width:38px;height:38px;border-radius:10px;background:rgba(255,255,255,.14);display:grid;place-items:center;flex-shrink:0;">@Icons.Render("eye", 18)</div>
                    <div style="flex:1;min-width:0;">
                        <div style="font-weight:700;font-size:15px;font-family:var(--font-display);">Conteúdo · @(Model.Reveal.Type == "channel" ? "#" + Model.Reveal.Name : "conversa direta")</div>
                        <div style="font-size:12px;font-weight:600;opacity:.8;">@Model.Reveal.TenantName · acesso registado</div>
                    </div>
                    <button class="icon-btn" type="button" style="width:34px;height:34px;background:rgba(255,255,255,.12);border:none;color:#fff;" onclick="document.getElementById('revOv').style.display='none'">@Icons.Render("x", 17)</button>
                </div>
                <div style="display:flex;flex-wrap:wrap;gap:8px;margin-top:13px;">
                    <span style="display:inline-flex;align-items:center;gap:6px;padding:5px 11px;border-radius:var(--r-pill);background:rgba(255,255,255,.14);color:#fff;font-size:12px;font-weight:700;">@Icons.Render("shield", 12) @Model.RevealEntry.Ref</span>
                    <span style="display:inline-flex;align-items:center;gap:6px;padding:5px 11px;border-radius:var(--r-pill);background:rgba(255,255,255,.14);color:#fff;font-size:12px;font-weight:700;">@Model.RevealEntry.LegalBasis</span>
                </div>
            </div>
            <div style="padding:22px;max-height:380px;overflow-y:auto;background:var(--surface-2);">
                <div style="display:flex;flex-direction:column;gap:10px;">
                    @foreach (var m in Model.RevealMessages)
                    {
                        <div style="display:flex;align-items:flex-end;gap:9px;">
                            @Components.Avatar(m.Sender?.Name, 28)
                            <div>
                                <div class="muted-3" style="font-size:11.5px;font-weight:700;margin-bottom:3px;padding-inline:3px;">@(m.Sender?.Name ?? "—") · @m.CreatedAt.ToString("HH:mm")</div>
                                <div style="max-width:78%;min-width:120px;padding:10px 14px;border-radius:14px;font-size:13.5px;line-height:1.5;background:var(--surface);border:1px solid var(--border);color:var(--text);">@m.Body</div>
                            </div>
                        </div>
                    }
                    @if (Model.RevealMessages.Count == 0) { <div class="muted" style="font-size:13px;font-weight:600;">Sem mensagens neste canal.</div> }
                </div>
            </div>
            <div style="padding:14px 22px;border-top:1px solid var(--border);display:flex;align-items:center;gap:10px;background:var(--surface);">
                @Icons.Render("shield", 15)
                <div class="muted-3" style="font-size:12px;font-weight:600;flex:1;line-height:1.5;">Este acesso ficou registado no ChatComplianceAccessLog e pode ser auditado. Os titulares dos dados podem ser notificados.</div>
                <button class="btn btn-primary btn-sm" type="button" onclick="document.getElementById('revOv').style.display='none'">Concluir</button>
            </div>
        </div>
    </div>
}

<script>
    function openAccess(id, name, tenant, count, msgs) {
        document.getElementById('accChannel').value = id;
        document.getElementById('accName').textContent = name;
        document.getElementById('accMeta').textContent = tenant + ' · ' + count + ' participante' + (count === 1 ? '' : 's') + ' · ' + msgs + ' mensagens (30 d)';
        document.getElementById('accOv').style.display = 'grid';
    }
    document.addEventListener('keydown', e => { if (e.key === 'Escape') { document.getElementById('accOv').style.display = 'none'; var r = document.getElementById('revOv'); if (r) r.style.display = 'none'; } });
</script>
