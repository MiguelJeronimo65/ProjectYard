@model TimeEntry
@{
    ViewData["Title"] = "Registar horas";
    var projects = (List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)ViewBag.Projects;
    var users = (List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)ViewBag.Users;
    var tipos = new[] { "Produção", "Coordenação", "Licenciamento", "Assistência", "Reunião", "Gestão" };
    string sel() => "border:none;outline:none;background:transparent;flex:1;font-size:14px;";
}
<div class="content">
    <div class="page-head"><div><h1>Registar horas</h1></div></div>
    <form asp-action="Create" method="post" class="card card-pad" style="max-width:720px;">
        <div asp-validation-summary="ModelOnly" class="login__error"></div>
        <div class="grid" style="grid-template-columns:1fr 1fr;gap:16px;">
            <div class="fld"><label asp-for="EntryDate">Data</label><div class="fld__box"><input asp-for="EntryDate" type="date" style="@sel()" /></div><span asp-validation-for="EntryDate" class="fld__msg"></span></div>
            <div class="fld"><label asp-for="UserId">Colaborador</label><div class="fld__box"><select asp-for="UserId" asp-items="users" style="@sel()"></select></div></div>
            <div class="fld"><label asp-for="ProjectId">Projeto</label><div class="fld__box"><select asp-for="ProjectId" asp-items="projects" style="@sel()"><option value="">— Interno —</option></select></div></div>
            <div class="fld"><label asp-for="Type">Tipo</label><div class="fld__box"><select asp-for="Type" style="@sel()">@foreach (var t in tipos){<option value="@t" selected="@(Model.Type == t)">@t</option>}</select></div></div>
            <div class="fld"><label asp-for="Hours">Horas</label><div class="fld__box"><input asp-for="Hours" type="number" step="0.25" min="0" style="@sel()" /></div><span asp-validation-for="Hours" class="fld__msg"></span></div>
            <div class="fld"><label asp-for="Billable">Faturável</label><div class="fld__box"><select asp-for="Billable" style="@sel()"><option value="true">Sim</option><option value="false">Não</option></select></div></div>
            <div class="fld" style="grid-column:1/-1;"><label asp-for="Description">Descrição</label><div class="fld__box"><input asp-for="Description" placeholder="Ex.: Cálculo estrutural piso 2" /></div></div>
        </div>
        <div style="display:flex;gap:10px;margin-top:18px;">
            <button class="btn btn-primary" type="submit">Guardar</button>
            <a class="btn btn-ghost" asp-action="Index">Cancelar</a>
        </div>
    </form>
</div>
