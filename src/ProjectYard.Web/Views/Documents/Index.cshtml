@model List<Document>
@{ ViewData["Title"] = "Documentos"; }
<div class="content">
    <div class="page-head"><div><h1>Documentos</h1><p>@Model.Count documentos na base documental.</p></div></div>
    <div class="card">
        <table class="tbl">
            <thead><tr><th>Nome</th><th>Projeto</th><th>Pasta</th><th>Tipo</th><th>Versão</th><th>Carregado por</th><th>Quando</th></tr></thead>
            <tbody>
            @foreach (var d in Model)
            {
                <tr>
                    <td style="font-weight:700;">@d.Name</td>
                    <td><span class="badge b-gray">@(d.Project?.Code ?? "—")</span></td>
                    <td>@(d.Folder ?? "—")</td>
                    <td><span class="badge b-blue">@(d.Ext ?? "—")</span></td>
                    <td>@(d.Version ?? "—")</td>
                    <td>@(d.Uploader?.Name ?? "—")</td>
                    <td class="muted">@Ui.Date(d.UploadedAt)</td>
                </tr>
            }
            @if (Model.Count == 0) { <tr><td colspan="7" class="muted" style="padding:24px;">Sem documentos.</td></tr> }
            </tbody>
        </table>
    </div>
</div>
