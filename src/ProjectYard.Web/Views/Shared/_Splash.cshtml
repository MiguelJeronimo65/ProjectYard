@* Splash de arranque (SPEC-splash-loader.md) — mostrado UMA vez por sessão de browser.
   Decisão server-side via cookie de sessão "py_splash" para não haver flash da app antes do JS. *@
@if (!Context.Request.Cookies.ContainsKey("py_splash"))
{
    <div class="py-splash" id="pySplash" role="status" aria-live="polite">
        <div class="py-splash__bg">
            <div class="py-splash__grid"></div>
            <div class="py-splash__reticle tl"></div>
            <div class="py-splash__reticle br"></div>
        </div>
        <div class="py-splash__stage">
            <img class="py-splash__logo" src="~/assets/projectyard-logo-full.jpg" alt="ProjectYard — Plan. Build. Deliver." />
            <div class="py-splash__pbar"><i></i></div>
            <div class="py-splash__ldg"><i>A</i> <i>carregar</i> <i>&hellip;</i></div>
        </div>
        <div class="py-splash__foot"><div class="tag">Plan <b>&middot;</b> Build <b>&middot;</b> Deliver</div></div>
    </div>
    <script>
        (function () {
            var t0 = performance.now();
            var MIN = 1200; // não "piscar"
            function dismiss() {
                var el = document.getElementById('pySplash');
                if (!el) return;
                var wait = Math.max(0, MIN - (performance.now() - t0));
                setTimeout(function () {
                    el.classList.add('done');
                    document.cookie = 'py_splash=1;path=/;SameSite=Lax';
                    setTimeout(function () { el.remove(); }, 500);
                }, wait);
            }
            if (document.readyState === 'complete') dismiss();
            else window.addEventListener('load', dismiss);
        })();
    </script>
}
