@model List<Client>
@{ ViewData["Title"] = "Clientes"; }
<div class="content">
    <div class="page-head"><div><h1>Clientes</h1><p>@Model.Count clientes no teu workspace.</p></div></div>
    <div class="card">
        <table class="tbl">
            <thead><tr><th>Empresa</th><th>NIF</th><th>Contacto</th><th>Email</th><th>Cidade</th><th>Estado</th></tr></thead>
            <tbody>
            @foreach (var c in Model)
            {
                <tr>
                    <td style="font-weight:700;">@c.Company</td>
                    <td>@(c.Nif ?? "—")</td>
                    <td>@(c.Contact ?? "—")</td>
                    <td class="muted">@(c.Email ?? "—")</td>
                    <td>@(c.City ?? "—")</td>
                    <td><span class="badge @Ui.ClientStatus(c.Status)">@c.Status</span></td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
